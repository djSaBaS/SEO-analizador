# Clave opcional para enriquecer el informe con Google AI Studio.
GEMINI_API_KEY=[API KEY GOOGLE IA STUDIO]

# Clave opcional para habilitar Google PageSpeed Insights API.
PAGESPEED_API_KEY=[API KEY PAGESPEED INSIGHTS]

# Modelo por defecto de Gemini para el proyecto.
GEMINI_MODEL=gemini-2.5-flash

# Tiempo máximo de espera para peticiones HTTP en segundos.
HTTP_TIMEOUT=15

# Límite de URLs a analizar por ejecución.
MAX_URLS=500

# Límite de URLs a analizar con PageSpeed por ejecución.
MAX_PAGESPEED_URLS=5

# Timeout de PageSpeed Insights en segundos (valor recomendado para reducir timeouts).
PAGESPEED_TIMEOUT=45

# Reintentos de PageSpeed Insights por URL/estrategia.
PAGESPEED_REINTENTOS=2

# Activa integración opcional de Google Search Console.
GSC_ENABLED=false

# Propiedad verificada de Search Console (URL-prefix o sc-domain).
GSC_SITE_URL=https://www.midominio.com/

# Ruta al JSON de service account con permisos de lectura en la propiedad.
GSC_CREDENTIALS_FILE=./credenciales/gsc-service-account.json

# Fecha de inicio de consulta de Search Console.
GSC_DATE_FROM=YYYY-MM-DD

# Fecha de fin de consulta de Search Console.
GSC_DATE_TO=YYYY-MM-DD

# Límite de filas por consulta de Search Console.
GSC_ROW_LIMIT=250

# Activa integración opcional de Google Analytics 4.
GA_ENABLED=false

# Property ID de Google Analytics 4.
GA_PROPERTY_ID=XXXXXXXXX

# Ruta al JSON de service account con permisos de lectura en la propiedad GA4.
GA_CREDENTIALS_FILE=./credenciales/ga-service-account.json

# Fecha de inicio de consulta de Analytics 4.
GA_DATE_FROM=YYYY-MM-DD

# Fecha de fin de consulta de Analytics 4.
GA_DATE_TO=YYYY-MM-DD
